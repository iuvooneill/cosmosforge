{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "AllowPublicRead",
      "Effect": "Allow",
      "Principal": "*",
      "Action": "s3:GetObject",
      "Resource": "arn:aws:s3:::{{ s3_bucket }}/*"
    },
    {
      "Sid": "DenyKSFromNonAllowedIPs",
      "Effect": "Deny",
      "Principal": "*",
      "Action": "s3:*",
      "Resource": "arn:aws:s3:::{{ s3_bucket }}/ks/*",
      "Condition": {
        "NotIpAddress": {
          "aws:SourceIp": {{ s3_bucket_allowed_ips | to_json }}
        },
        "ForAllValues:StringNotEquals": {
          "aws:PrincipalAccount": ["116741075323", "520770367931"]
        }
      }
    }
  ]
}
